# Если вы используете VS Code
.vscode/
.idea/

# Скомпилированные бинарные файлы (самое важное!)
# Ваш скомпилированный бинарник (если он называется, например, "myapp" или "server")
/myapp
/server
# Либо всё, что является исполняемым файлом в корне
*.exe
*.exe~
*.dll
*.so
*.dylib

# Директория зависимостей (если вы используете go mod vendor)
# Обычно vendor не хранят в репозитории, чтобы не раздувать историю, если только вы не пишете библиотеку для "заморозки" версий.
/vendor/

# Временные файлы и файлы тестов
*.test
*.prof
profile.out
cover.html
coverage.out
# Директория с результатами тестов (если настроено)
/testdata/

# Логи и базы данных
*.log
*.db
*.sqlite
*.db-shm
*.db-wal

# Файлы среды окружения (важно! часто содержат пароли)
.env
.env.local
.env.production

# Директория временной сборки (если вы собираете в папку, например, /bin или /dist)
/bin/
/dist/
/build/

# OS metadata
.DS_Store  # Mac
Thumbs.db  # Windows